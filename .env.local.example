# ── Neon PostgreSQL ──────────────────────────────────────
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require

# ── JWT Secret (generate a random 64-char string) ────────
JWT_SECRET=replace_with_a_long_random_secret_string_at_least_64_chars

# ── Cloudflare R2 ─────────────────────────────────────────
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=ss-traders-dms
R2_PUBLIC_URL=https://your-bucket.your-account.r2.cloudflarestorage.com
